---
interface Props {
  title: string;
  variant?: "theorem" | "lemma" | "corollary" | "proof" | "proposition";
  id?: string;
}

const { title, variant = "theorem", id } = Astro.props;

const labelMap = {
  theorem: "Theorem",
  lemma: "Lemma",
  corollary: "Corollary",
  proof: "Proof",
  proposition: "Proposition",
} as const;
---

<figure class={`article-theorem article-theorem--${variant}`} id={id}>
  <figcaption class="article-theorem__title">{labelMap[variant]}: {title}</figcaption>
  <div class="article-theorem__body">
    <slot />
  </div>
</figure>
