---
import BaseLayout from "../layouts/BaseLayout.astro";
import { browseCategoryHref, browseTagHref } from "../utils/browse-links";
import { parseArticleGlob } from "../utils/site-articles";
import { getAllArticleBundleLastModifiedIso } from "../utils/article-modified";

const articleGlob = import.meta.glob<{ frontmatter: Record<string, unknown> }>(
  "../content/*/article.{md,mdx}",
  { eager: true },
);

const modifiedBySlug = await getAllArticleBundleLastModifiedIso();
const articles = await parseArticleGlob(articleGlob, modifiedBySlug);

const pageTitle = "Blog";
const description =
  "Articles and papers — research-style posts published from this site.";
---
<BaseLayout
  pageTitle={pageTitle}
  description={description}
  contentClass="site-page--blog"
>
  <p class="site-lead">
    Notes, tutorials, and longer-form writing. 
    <a href="/browse">Search and filter by tags or category →</a>
  </p>

  {
    articles.length === 0 ? (
      <p>No posts yet. Add a folder under <code>src/content/</code> with an <code>article.md</code> or <code>article.mdx</code>.</p>
    ) : (
      <section aria-labelledby="posts-heading">
        <h2 id="posts-heading">All posts</h2>
        <ul class="article-index">
          {articles.map(
            ({
              url,
              title,
              displayDate,
              description: desc,
              categories,
              tags,
            }) => (
              <li class="article-index__item">
                {categories ? (
                  <a class="article-index__category" href={browseCategoryHref(categories)}>
                    {categories}
                  </a>
                ) : null}
                <a class="article-index__link" href={url}>
                  {title}
                </a>
                {displayDate ? (
                  <span class="article-index__meta">{displayDate}</span>
                ) : null}
                {desc ? <p class="article-index__desc">{desc}</p> : null}
                {tags.length > 0 ? (
                  <div class="article-index__tags">
                    {tags.map((t) => (
                      <a class="article-index__tag" href={browseTagHref(t)}>
                        {t}
                      </a>
                    ))}
                  </div>
                ) : null}
              </li>
            ),
          )}
        </ul>
      </section>
    )
  }
</BaseLayout>
